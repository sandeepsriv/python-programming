   "source": [
    "# Simple Filter function\n",
    "\n",
    "num = [ 4, 5, 6, 7, 8, 9, 10, 12]\n",
    "\n",
    "def even_number(n):\n",
    "    if n%2==0:\n",
    "        return True\n",
    "\n",
    "list(filter(even_number, num))"
   ]
  },
