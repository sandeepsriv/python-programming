   ],
   "source": [
    "# Filters with Lambda function\n",
    "\n",
    "num = [ 4, 5, 6, 7, 8, 9, 10, 12]\n",
    "\n",
    "list(filter((lambda n:(n%2==0)), num))"
   ]
  },
